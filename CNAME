                <!-- JS will populate 12+ programs with pricing -->
            </div>
            <div style="text-align: center; margin-top: 40px;">
                <button class="cta-btn" onclick="document.getElementById('enquiry').scrollIntoView({behavior:'smooth'})">Request Full Catalogue & Group Pricing →</button>
            </div>
        </div>
    </section>

    <!-- Hardware & Infrastructure Showcase -->
