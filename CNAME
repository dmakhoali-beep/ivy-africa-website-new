<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ivy Africa | Workforce Infrastructure. National Scale.</title>
    <meta name="description" content="Government-trusted, B-BBEE Level 1 workforce transformation. Infrastructure systems for Africa's future.">
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    
    <!-- GSAP animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    
    <style>
:root {
    --background: #0A0A0F;
    --surface: #111318;
    --surface-elevated: #1A1D24;
    --primary: #00D4AA;
    --primary-glow: rgba(0,212,170,0.2);
    --accent-cyan: #00B8D9;
    --text-primary: #FFFFFF;
    --text-secondary: #A0A5B5;
    --border-subtle: rgba(255,255,255,0.08);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background-color: var(--background);
    color: var(--text-primary);
    font-family: 'Inter', system-ui, sans-serif;
    line-height: 1.6;
    overflow-x: hidden;
}

/* Navigation */
.navbar {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
    background: rgba(10, 10, 15, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
    padding: 1rem 0;
}

.nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary);
    text-decoration: none;
}

.nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    align-items: center;
}

.nav-links a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.3s ease;
    font-size: 0.95rem;
}

.nav-links a:hover {
    color: var(--primary);
}

.nav-cta {
    padding: 0.5rem 1rem !important;
    background: var(--primary);
    color: var(--background) !important;
    border-radius: 4px;
    font-weight: 600;
}

/* Hero */
.hero {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    margin-top: 60px;
}

.hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
}

#grid-canvas {
    display: block;
    width: 100%;
    height: 100%;
}

.orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.3;
}

.orb-1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, #00D4AA, transparent);
    top: 10%;
    right: 5%;
    animation: float-orb 20s ease-in-out infinite;
}

.orb-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, #00B8D9, transparent);
    bottom: 10%;
    left: 5%;
    animation: float-orb 25s ease-in-out infinite reverse;
}

@keyframes float-orb {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(30px, -30px); }
}

.hero-content {
    position: relative;
    z-index: 10;
    max-width: 900px;
    text-align: center;
    padding: 0 2rem;
}

.badge {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: rgba(0, 212, 170, 0.1);
    border: 1px solid var(--primary);
    border-radius: 50px;
    color: var(--primary);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    margin-bottom: 2rem;
}

.fade-up-anim {
    animation: fadeUp 0.8s ease-out forwards;
    opacity: 0;
}

@keyframes fadeUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.hero-headline {
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1rem;
}

.hero-headline .accent {
    color: var(--primary);
    display: block;
}

.hero-subheading {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.8;
}

.cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 3rem;
    flex-wrap: wrap;
}

.btn {
    padding: 0.75rem 1.5rem;
    border-radius: 4px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.25s ease-out;
    border: 1px solid transparent;
    display: inline-block;
    cursor: pointer;
}

.btn-primary {
    background: var(--primary);
    color: var(--background);
    box-shadow: 0 0 20px rgba(0, 212, 170, 0.2);
}

.btn-primary:hover {
    transform: scale(1.02);
    box-shadow: 0 0 40px rgba(0, 212, 170, 0.4);
}

.btn-secondary {
    background: transparent;
    color: var(--primary);
    border: 1px solid var(--primary);
}

.btn-secondary:hover {
    background: rgba(0, 212, 170, 0.1);
    transform: scale(1.02);
}

.btn-outline {
    background: transparent;
    color: var(--primary);
    border: 1px solid var(--primary);
    padding: 0.6rem 1.2rem;
    font-size: 0.9rem;
}

.btn-outline:hover {
    background: rgba(0, 212, 170, 0.1);
}

.btn.large {
    padding: 1rem 2rem;
    font-size: 1rem;
}

.trust-row {
    margin-top: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
}

.trust-label {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 600;
}

.logo-grid {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
}

.partner-logo {
    padding: 0.5rem 1rem;
    color: var(--text-secondary);
    font-size: 0.85rem;
    font-weight: 600;
    transition: color 0.3s ease;
    cursor: pointer;
}

.partner-logo:hover {
    color: var(--primary);
}

.metrics-row {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 3rem;
    flex-wrap: wrap;
    padding-top: 3rem;
    border-top: 1px solid var(--border-subtle);
}

.metric {
    text-align: center;
}

.metric-value {
    font-size: 2rem;
    font-weight: 800;
    color: var(--primary);
}

.metric-label {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-top: 0.5rem;
}

.metric-divider {
    height: 3rem;
    width: 1px;
    background: var(--border-subtle);
}

.scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
}

.scroll-arrow {
    width: 2px;
    height: 20px;
    background: var(--primary);
    display: block;
    margin: 0 auto;
    animation: bounce 2s infinite;
}

@keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(10px); }
    60% { transform: translateY(5px); }
}

/* System Section */
.system-section {
    padding: 6rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
}

.section-header {
    text-align: center;
    margin-bottom: 4rem;
}

.section-header h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
}

.section-header p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 500px;
    margin: 0 auto;
}

.system-stack {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
}

.system-layer {
    padding: 2rem;
    background: var(--surface-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    transition: all 0.3s ease;
    cursor: pointer;
}

.system-layer:hover {
    transform: scale(1.02);
    border-color: var(--primary);
    box-shadow: 0 0 30px var(--primary-glow);
}

.layer-number {
    font-family: 'JetBrains Mono', monospace;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--primary);
    opacity: 0.3;
    margin-bottom: 1rem;
}

.layer-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
}

.layer-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
}

.layer-details {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-subtle);
}

.layer-details ul {
    list-style: none;
}

.layer-details li {
    color: var(--text-secondary);
    font-size: 0.9rem;
    padding: 0.5rem 0;
    padding-left: 1rem;
}

.layer-details li:before {
    content: "→ ";
    color: var(--primary);
    margin-right: 0.5rem;
}

.layer-details.hidden {
    display: none;
}

/* Sector Section */
.sector-section {
    padding: 6rem 2rem;
    background: var(--surface);
}

.sector-section h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    text-align: center;
    margin-bottom: 3rem;
}

.sector-tabs {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
}

.sector-tab {
    padding: 0.75rem 1.5rem;
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: 4px;
    cursor: pointer;
    font-weight: 600;
    transition: all 0.3s ease;
    font-size: 0.95rem;
}

.sector-tab.active,
.sector-tab:hover {
    background: var(--primary);
    color: var(--background);
    border-color: var(--primary);
}

.sector-content {
    position: relative;
}

.sector-panel {
    display: none;
    animation: fadeIn 0.5s ease-out;
}

.sector-panel.active {
    display: block;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.sector-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
}

@media (max-width: 768px) {
    .sector-grid {
        grid-template-columns: 1fr;
    }
}

.sector-text h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
}

.challenge-intro {
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-size: 0.95rem;
}

.solution-stat {
    margin-bottom: 1.5rem;
    padding: 1.5rem;
    background: var(--surface-elevated);
    border-left: 3px solid var(--primary);
    border-radius: 4px;
}

.stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 0.25rem;
}

.stat-label {
    display: block;
    color: var(--text-secondary);
    font-size: 0.85rem;
}

.featured-case {
    padding: 2rem;
    background: var(--surface-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
}

.featured-case h4 {
    color: var(--primary);
    margin-bottom: 1rem;
    font-size: 1.1rem;
}

.case-metric {
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-primary);
}

.case-quote {
    color: var(--text-secondary);
    font-size: 0.95rem;
    font-style: italic;
    margin-top: 1rem;
}

/* Outcomes Section */
.outcomes-section {
    padding: 6rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
}

.outcomes-section h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    text-align: center;
    margin-bottom: 3rem;
}

.outcomes-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
}

@media (max-width: 768px) {
    .outcomes-grid {
        grid-template-columns: 1fr;
    }
}

.outcome-card {
    padding: 2.5rem;
    background: var(--surface-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    transition: all 0.3s ease;
}

.outcome-card:hover {
    transform: translateY(-5px);
    border-color: var(--primary);
    box-shadow: 0 10px 40px rgba(0, 212, 170, 0.15);
}

.outcome-client {
    color: var(--primary);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.outcome-metric {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
}

.metric-primary {
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--primary);
}

.metric-secondary {
    color: var(--text-secondary);
    font-size: 0.95rem;
}

.outcome-quote {
    color: var(--text-secondary);
    font-style: italic;
    margin-bottom: 2rem;
    font-size: 0.95rem;
    line-height: 1.8;
}

.outcome-visual {
    height: 150px;
    background: linear-gradient(135deg, rgba(0, 212, 170, 0.1), rgba(0, 184, 217, 0.05));
    border: 1px solid var(--border-subtle);
    border-radius: 4px;
    margin-bottom: 1.5rem;
}

.outcome-link {
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
    display: inline-flex;
    gap: 0.5rem;
    transition: gap 0.3s ease;
}

.outcome-link:hover {
    gap: 1rem;
}

/* Trust Section */
.trust-section {
    padding: 6rem 2rem;
    background: var(--surface);
}

.trust-section h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    text-align: center;
    margin-bottom: 3rem;
}

.partner-wall {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
    margin-bottom: 3rem;
}

.partner-item {
    padding: 2rem;
    background: var(--surface-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    text-align: center;
    color: var(--text-secondary);
    font-weight: 600;
    transition: all 0.3s ease;
    cursor: pointer;
}

.partner-item:hover {
    color: var(--primary);
    border-color: var(--primary);
    box-shadow: 0 0 20px var(--primary-glow);
}

.trust-credentials {
    text-align: center;
    padding: 2rem;
    background: var(--surface-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.8;
}

.trust-credentials strong {
    color: var(--primary);
}

/* Contact Section */
.contact-section {
    padding: 6rem 2rem;
    text-align: center;
    max-width: 1200px;
    margin: 0 auto;
}

.contact-section h2 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 1rem;
}

.contact-section > p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
}

.contact-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
}

/* Footer */
.footer {
    background: var(--surface);
    padding: 3rem 2rem 2rem;
    border-top: 1px solid var(--border-subtle);
}

.footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
}

.footer-col h4 {
    color: var(--text-primary);
    margin-bottom: 1rem;
    font-size: 0.95rem;
}

.footer-col ul {
    list-style: none;
}

.footer-col a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.3s ease;
}

.footer-col a:hover {
    color: var(--primary);
}

.footer-col li {
    margin-bottom: 0.5rem;
}

.footer-bottom {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid var(--border-subtle);
    color: var(--text-secondary);
    font-size: 0.85rem;
}

.social-links {
    margin-top: 1rem;
}

.social-links a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.3s ease;
}

.social-links a:hover {
    color: var(--primary);
}

/* Responsive */
@media (max-width: 768px) {
    .nav-links {
        gap: 1rem;
    }

    .hero {
        margin-top: 80px;
    }

    .metrics-row {
        gap: 1rem;
    }

    .metric-divider {
        display: none;
    }

    .system-stack {
        grid-template-columns: 1fr;
    }

    .sector-tabs {
        gap: 0.5rem;
    }

    .sector-tab {
        padding: 0.5rem 1rem;
        font-size: 0.85rem;
    }

    .outcomes-grid {
        grid-template-columns: 1fr;
    }

    .partner-wall {
        grid-template-columns: repeat(2, 1fr);
    }

    .contact-ctas {
        flex-direction: column;
        width: 100%;
    }

    .contact-ctas .btn {
        width: 100%;
    }
}

.counter {
    font-variant-numeric: tabular-nums;
}
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="#" class="logo">Ivy Africa</a>
            <ul class="nav-links">
                <li><a href="#system">Solutions</a></li>
                <li><a href="#sectors">Sectors</a></li>
                <li><a href="#outcomes">Impact</a></li>
                <li><a href="#contact" class="nav-cta">Start Conversation</a></li>
            </ul>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-background">
            <canvas id="grid-canvas"></canvas>
            <div class="orb orb-1"></div>
            <div class="orb orb-2"></div>
        </div>

        <div class="hero-content">
            <div class="badge fade-up-anim" style="animation-delay: 0s;">
                Government-Ready · B-BBEE Level 1 · CSD Registered
            </div>

            <h1 class="hero-headline fade-up-anim" style="animation-delay: 0.1s;">
                Building the infrastructure
                <span class="accent">for Africa's future workforce</span>
            </h1>

            <p class="hero-subheading fade-up-anim" style="animation-delay: 0.2s;">
                Skills intelligence · Digital transformation · National capability systems
                <br>
                Partnering with governments, enterprises, and institutions across South Africa
            </p>

            <div class="cta-group fade-up-anim" style="animation-delay: 0.3s;">
                <a href="#system" class="btn btn-primary">Explore Solutions →</a>
                <a href="#outcomes" class="btn btn-secondary">View Impact ←</a>
            </div>

            <div class="trust-row fade-up-anim" style="animation-delay: 0.4s;">
                <div class="trust-label">Authorised & Accredited Partners:</div>
                <div class="logo-grid">
                    <div class="partner-logo">Dell</div>
                    <div class="partner-logo">HP</div>
                    <div class="partner-logo">Lenovo</div>
                    <div class="partner-logo">Cisco</div>
                    <div class="partner-logo">CompTIA</div>
                    <div class="partner-logo">ISACA</div>
                    <div class="partner-logo">PECB</div>
                </div>
            </div>

            <div class="metrics-row fade-up-anim" style="animation-delay: 0.5s;">
                <div class="metric">
                    <div class="metric-value counter" data-target="2016">2016</div>
                    <div class="metric-label">Founded</div>
                </div>
                <div class="metric-divider"></div>
                <div class="metric">
                    <div class="metric-value counter" data-target="1200">1,200</div>
                    <div class="metric-label">Govt Transactions</div>
                </div>
                <div class="metric-divider"></div>
                <div class="metric">
                    <div class="metric-value"><span class="counter" data-target="90">90</span>%</div>
                    <div class="metric-label">Certification Pass Rate</div>
                </div>
                <div class="metric-divider"></div>
                <div class="metric">
                    <div class="metric-value counter" data-target="45">45</div>
                    <div class="metric-label">Schools Transformed</div>
                </div>
            </div>
        </div>

        <div class="scroll-indicator">
            <div class="scroll-arrow"></div>
        </div>
    </section>

    <!-- System Section -->
    <section id="system" class="system-section">
        <div class="container">
            <div class="section-header">
                <h2>A unified system for national capability</h2>
                <p>Not services. Not courses. An integrated intelligence layer.</p>
            </div>

            <div class="system-stack">
                <div class="system-layer" data-layer="1">
                    <div class="layer-number">01</div>
                    <h3 class="layer-title">Intelligence</h3>
                    <p class="layer-desc">Workforce analytics, skills gap mapping, AI diagnostics</p>
                    <div class="layer-details hidden">
                        <ul>
                            <li>Real-time workforce analytics dashboard</li>
                            <li>Predictive skills gap identification</li>
                            <li>AI-powered diagnostic assessments</li>
                        </ul>
                    </div>
                </div>

                <div class="system-layer" data-layer="2">
                    <div class="layer-number">02</div>
                    <h3 class="layer-title">Infrastructure</h3>
                    <p class="layer-desc">LMS ecosystems, certification pathways, partner integration</p>
                    <div class="layer-details hidden">
