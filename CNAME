</footer>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
    // Partners list (full color logos - strategic showcase)
    const partners = [
        { name: "Dell Technologies", logo: "https://upload.wikimedia.org/wikipedia/commons/1/18/Dell_Technologies_logo.svg" },
        { name: "Huawei", logo: "https://upload.wikimedia.org/wikipedia/commons/e/e8/Huawei_Logo.jpg" },
        { name: "Apple", logo: "https://upload.wikimedia.org/wikipedia/commons/f/fa/Apple_logo_black.svg" },
        { name: "IBM", logo: "https://upload.wikimedia.org/wikipedia/commons/5/51/IBM_logo.svg" },
        { name: "Microsoft", logo: "https://upload.wikimedia.org/wikipedia/commons/4/44/Microsoft_logo.svg" },
        { name: "Cisco", logo: "https://upload.wikimedia.org/wikipedia/commons/0/08/Cisco_logo_blue_2016.svg" },
        { name: "PECB", logo: "https://upload.wikimedia.org/wikipedia/commons/7/79/PECB_Logo.svg" },
        { name: "CompTIA", logo: "https://upload.wikimedia.org/wikipedia/commons/2/2b/CompTIA_logo.svg" }
    ];
    const carouselContainer = document.getElementById('partnerCarousel');
    if(carouselContainer) {
        partners.forEach(p => {
            let slide = document.createElement('div');
            slide.className = 'swiper-slide';
            slide.innerHTML = `<img src="${p.logo}" alt="${p.name}" class="partner-logo" onerror="this.src='https://placehold.co/200x80?text=${p.name}'">`;
            carouselContainer.appendChild(slide);
        });
    }
    new Swiper('.partnerSwiper', {
        slidesPerView: 2,
        spaceBetween: 20,
        loop: true,
        autoplay: { delay: 3500, disableOnInteraction: false },
        pagination: { el: '.swiper-pagination', clickable: true },
        navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
        breakpoints: { 768: { slidesPerView: 3 }, 1024: { slidesPerView: 4 } }
    });

    // Training programs with pricing (B2C transparent)
    const programs = [
        { name: "CompTIA A+", vendor: "CompTIA", price: "R9,500", group: "R7,800 pp" },
        { name: "CCNA (Cisco)", vendor: "Cisco", price: "R15,000", group: "R12,500 pp" },
        { name: "ISO 27001 Lead Implementer", vendor: "PECB", price: "R18,500", group: "R15,000 pp" },
        { name: "AWS Solutions Architect", vendor: "AWS", price: "R14,000", group: "R11,500 pp" },
        { name: "Microsoft Azure (AZ-104)", vendor: "Microsoft", price: "R12,500", group: "R10,000 pp" },
        { name: "CompTIA Security+", vendor: "CompTIA", price: "R10,500", group: "R8,800 pp" },
        { name: "ISO 22301 BCMS", vendor: "PECB", price: "R17,500", group: "R14,200 pp" },
        { name: "Cisco CyberOps", vendor: "Cisco", price: "R14,500", group: "R12,000 pp" }
    ];
    const grid = document.getElementById('programsGrid');
    if(grid) {
        programs.forEach(p => {
            let card = document.createElement('div');
            card.className = 'card';
            card.innerHTML = `
                <h3>${p.name}</h3>
                <p style="color: var(--grey-500); font-size:0.8rem;">${p.vendor}</p>
                <div class="price">${p.price} +VAT</div>
                <p style="font-size:0.75rem;">Group (3-5): ${p.group}</p>
                <button class="btn-sm" onclick="document.getElementById('enquiry').scrollIntoView({behavior:'smooth'})">Enroll / Quote</button>
            `;
            grid.appendChild(card);
        });
    }

    // Form submission (demo)
    const form = document.getElementById('leadForm');
    if(form) form.addEventListener('submit', (e) => { e.preventDefault(); alert('Thank you — an enterprise specialist will respond within 24 hours with pricing & availability.'); form.reset(); });
</script>
</body>
</html>
