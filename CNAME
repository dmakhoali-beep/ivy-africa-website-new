<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Ivy Africa | National Education & Technology Enterprise</title>
    <!-- Preconnect & Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Swiper JS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: #FFFFFF;
            color: #111111;
            line-height: 1.5;
            scroll-behavior: smooth;
        }

        :root {
            --black: #000000;
            --white: #FFFFFF;
            --grey-50: #F9F9F9;
            --grey-100: #F2F2F2;
            --grey-200: #E8E8E8;
            --grey-300: #D4D4D4;
            --grey-500: #737373;
            --grey-700: #404040;
            --grey-900: #1A1A1A;
            --border-light: #EAEAEA;
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.02), 0 1px 2px rgba(0,0,0,0.03);
            --shadow-md: 0 8px 24px rgba(0,0,0,0.04), 0 2px 4px rgba(0,0,0,0.03);
            --shadow-lg: 0 24px 40px -12px rgba(0,0,0,0.08);
        }

        .container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 32px;
        }

        /* Typography */
        h1, h2, h3 {
            font-weight: 700;
            letter-spacing: -0.02em;
        }

        h1 { font-size: 3.5rem; line-height: 1.2; }
        h2 { font-size: 2rem; margin-bottom: 1rem; }
        h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }

        .section-title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
        }
        .section-sub {
            color: var(--grey-700);
            max-width: 680px;
            margin-bottom: 3rem;
            font-size: 1rem;
        }

        /* Header & Navigation */
        .site-header {
            background: var(--white);
            border-bottom: 1px solid var(--border-light);
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(255,255,255,0.98);
            backdrop-filter: blur(4px);
        }
        .header-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 20px 0;
            gap: 32px;
            flex-wrap: wrap;
        }
        .logo-area {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .logo-img {
            height: 52px;
            width: auto;
            object-fit: contain;
        }
        .logo-text {
            font-weight: 700;
            font-size: 1.25rem;
            letter-spacing: -0.3px;
            border-left: 2px solid var(--grey-300);
            padding-left: 14px;
        }
        .logo-text span {
            font-size: 0.7rem;
            font-weight: 400;
            color: var(--grey-500);
            display: block;
        }

        /* Mega Menu */
        .nav-links {
            display: flex;
            gap: 24px;
            align-items: center;
        }
        .nav-item {
            position: relative;
        }
        .nav-link {
            font-weight: 500;
            font-size: 0.9rem;
            padding: 8px 0;
            display: flex;
            align-items: center;
            gap: 6px;
            cursor: pointer;
            color: var(--grey-700);
            transition: color 0.2s;
        }
        .nav-link:hover, .nav-link.active {
            color: var(--black);
        }
        .mega-menu {
            position: absolute;
            top: 100%;
            left: 0;
            background: var(--white);
            border-radius: 20px;
            box-shadow: var(--shadow-lg);
            opacity: 0;
            visibility: hidden;
            transition: all 0.2s ease;
            z-index: 100;
            min-width: 680px;
            border: 1px solid var(--border-light);
            padding: 28px;
            background: white;
        }
        .nav-item:hover .mega-menu {
            opacity: 1;
            visibility: visible;
            transform: translateY(4px);
        }
        .mega-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }
        .mega-col h4 {
            font-weight: 700;
            margin-bottom: 12px;
            font-size: 0.9rem;
            border-bottom: 1px solid var(--grey-200);
            padding-bottom: 6px;
        }
        .mega-col a {
            display: block;
            font-size: 0.85rem;
            padding: 6px 0;
            color: var(--grey-700);
            text-decoration: none;
        }
        .mega-col a:hover { color: var(--black); }

        .cta-btn {
            background: var(--black);
            color: white;
            padding: 10px 24px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
        }
        .cta-btn-outline {
            background: transparent;
            border: 1px solid var(--grey-500);
            color: var(--black);
        }

        /* Hero */
        .hero {
            padding: 72px 0 64px;
            background: var(--white);
        }
        .hero-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 56px;
            align-items: center;
        }
        .hero-badge {
            background: var(--grey-100);
            padding: 6px 14px;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 600;
            display: inline-block;
            margin-bottom: 24px;
        }
        .trust-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 24px;
            margin-top: 32px;
        }
        .hero-image img {
            width: 100%;
            border-radius: 24px;
            object-fit: cover;
            box-shadow: var(--shadow-md);
        }

        /* Partner Carousel */
        .partner-section {
            padding: 64px 0;
            background: var(--grey-50);
            border-top: 1px solid var(--border-light);
            border-bottom: 1px solid var(--border-light);
        }
        .swiper-slide {
            background: white;
            padding: 20px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid var(--border-light);
            min-height: 110px;
        }
        .partner-logo {
            max-width: 140px;
            max-height: 60px;
            filter: none;
            object-fit: contain;
        }

        /* Cards & Grids */
        .industry-grid, .offering-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 28px;
            margin: 32px 0;
        }
        .card {
            background: var(--white);
            border: 1px solid var(--border-light);
            border-radius: 24px;
            padding: 28px;
            transition: all 0.2s;
        }
        .card i {
            font-size: 2rem;
            margin-bottom: 20px;
        }
        .price {
            font-weight: 800;
            font-size: 1.5rem;
            margin: 12px 0;
        }
        .btn-sm {
            background: var(--black);
            color: white;
            padding: 8px 16px;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
            margin-top: 12px;
            border: none;
            cursor: pointer;
        }

        /* Enquiry Form */
        .enquiry-section {
            padding: 80px 0;
            background: var(--white);
        }
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 48px;
            background: var(--grey-50);
            border-radius: 32px;
            padding: 48px;
        }
        input, select, textarea {
            width: 100%;
            padding: 14px 18px;
            border: 1px solid var(--grey-300);
            border-radius: 16px;
            font-family: inherit;
            margin-top: 6px;
        }

        footer {
            background: var(--black);
            color: #ccc;
            padding: 56px 0 32px;
        }

        @media (max-width: 900px) {
            .hero-grid, .form-grid { grid-template-columns: 1fr; }
            h1 { font-size: 2.2rem; }
            .mega-menu { display: none; } /* fallback, but hover works on desktop */
            .nav-links { gap: 12px; flex-wrap: wrap; }
        }
    </style>
</head>
<body>

<header class="site-header">
    <div class="container header-inner">
        <div class="logo-area">
            <img src="https://placehold.co/400x120?text=Ivy+Africa" alt="Ivy Africa Logo" class="logo-img" onerror="this.style.display='none'">
