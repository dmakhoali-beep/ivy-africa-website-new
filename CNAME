                <div class="swiper-button-prev"></div>
            </div>
        </div>
    </section>

    <!-- Industries We Serve -->
    <section style="padding: 72px 0;">
        <div class="container">
            <h2 class="section-title">Industries We Serve</h2>
            <div class="section-sub">Tailored hardware, training & supply solutions for every sector — B2B & B2C ready.</div>
            <div class="industry-grid">
                <div class="card"><i class="fas fa-chart-line"></i><h3>Finance & Banking</h3><p>ISO 27001 certification, secure endpoints, data protection (Veeam), server infrastructure.</p></div>
                <div class="card"><i class="fas fa-hard-hat"></i><h3>Mining & Resources</h3><p>Ruggedized Dell Latitude, Huawei networking, safety PPE, digital literacy programs.</p></div>
                <div class="card"><i class="fas fa-store"></i><h3>Retail & FMCG</h3><p>POS hardware, office workstations, staff cybersecurity training, CompTIA Security+.</p></div>
                <div class="card"><i class="fas fa-hospital-user"></i><h3>Healthcare</h3><p>Clinic terminals (IVY-CLINIC), PACS storage, POPIA compliance training, APC power backup.</p></div>
