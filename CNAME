function showServiceDetail(key) {
  var d = svcData[key];
  document.getElementById('svcDetailImg').src = d.img;
  document.getElementById('svcDetailTitle').textContent = d.title;
  document.getElementById('svcDetailSub').textContent = d.sub;
  document.getElementById('svcDetailContent').innerHTML = d.content;
  document.getElementById('svcDetailSidebar').innerHTML = d.sidebar;
  showPage('service-detail');
}

// ── CONTACT FORM ──
function submitContactForm() {
  var fname = document.getElementById('cf-fname').value;
  var email = document.getElementById('cf-email').value;
  if (!fname || !email) { alert('Please fill in your name and email address.'); return; }
  var btn = document.querySelector('.form-submit-btn');
  btn.innerHTML = '✓ Message Sent — We\'ll respond within 1 business day';
  btn.style.background = '#2a8a37';
  btn.disabled = true;
}

// ── NAV LOGO FALLBACK ──
window.addEventListener('load', function() {
  var img = document.querySelector('.nav-logo img');
  if (img && (img.naturalWidth === 0 || img.complete === false)) {
    img.style.display = 'none';
    img.nextElementSibling.style.display = 'flex';
  }
});
