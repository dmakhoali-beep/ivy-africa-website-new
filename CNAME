                <div class="card"><i class="fas fa-server"></i><h3>IVY-SERVER-CORE-RACK</h3><p>Dell PowerEdge, RAID, hot-swap, on-prem backbone.</p><div class="price">Quote based</div><button class="btn-sm">Configure</button></div>
                <div class="card"><i class="fas fa-shield-alt"></i><h3>Trend Micro Deep Security</h3><p>Endpoint protection, ransomware defense, cloud suite.</p><div class="price">From R450/device/yr</div><button class="btn-sm">Enquire</button></div>
            </div>
        </div>
    </section>

    <!-- B2B + B2C Enquiry Hub -->
    <section id="enquiry" class="enquiry-section">
