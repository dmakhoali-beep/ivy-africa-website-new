                    </div>
                </div>
            </div>
            <div class="nav-item">
                <div class="nav-link">Industries <i class="fas fa-chevron-down"></i></div>
                <div class="mega-menu">
                    <div class="mega-grid">
                        <div class="mega-col"><a href="#">Finance & Banking</a><a href="#">Mining & Resources</a><a href="#">Retail & FMCG</a></div>
                        <div class="mega-col"><a href="#">Healthcare & Pharma</a><a href="#">Manufacturing</a><a href="#">Logistics & Transport</a></div>
                        <div class="mega-col"><a href="#">Education & Training</a><a href="#">Energy & Utilities</a><a href="#">Government</a></div>
                    </div>
                </div>
            </div>
            <div class="nav-item"><div class="nav-link">Training & Certifications</div></div>
            <div class="nav-item"><div class="nav-link">Hardware & Infrastructure</div></div>
            <div class="nav-item"><div class="nav-link">Supply & Logistics</div></div>
            <a href="#enquiry" class="cta-btn">Get Quote <i class="fas fa-arrow-right"></i></a>
        </div>
    </div>
</header>

<main>
    <!-- Hero Section -->
    <section class="hero">
        <div class="container hero-grid">
