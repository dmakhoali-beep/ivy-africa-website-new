                </div>
                <form id="leadForm">
                    <input type="text" placeholder="Full name" required>
                    <input type="email" placeholder="Work email" required style="margin-top: 12px;">
                    <input type="text" placeholder="Organization" style="margin-top: 12px;">
                    <select style="margin-top: 12px;">
                        <option>Training & Certification (B2C/B2B)</option>
                        <option>Enterprise Hardware / Staging</option>
                        <option>Bulk Supply / Stationery / PPE</option>
